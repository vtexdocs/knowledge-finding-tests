# Credentials for the knowledge-finding test suite.
# Copy this file to `.env` at the repo root and fill in the values.
# Never commit the real `.env` (it is gitignored).

# Algolia (internal-search Algolia path — deprecated, kept for on-demand runs)
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_API_KEY=

# Hybrid Search (internal-search default path)
HYBRID_SEARCH_API_URL=
HYBRID_SEARCH_INTERNAL_KEY=
